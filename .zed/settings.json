{
  "languages": {
    "Python": {
      "language_servers": ["ty", "ruff"],
      "format_on_save": "on",
      "formatter": {
        "language_server": {
          "name": "ruff"
        }
      },
      "code_actions_on_save": {
        "source.organizeImports.ruff": true,
        "source.fixAll.ruff": true
      }
    }
  },
  "lsp": {
    "ruff": {
      "binary": {
        "path_lookup": true
      }
    },
    "ty": {
      "binary": {
        "path_lookup": true
      }
    },
    "pyright": {
      "settings": {
        "python": {
          "analysis": {
            "extraPaths": ["packages"]
          },
          "venvPath": ".",
          "venv": ".venv"
        }
      }
    }
  }
}
